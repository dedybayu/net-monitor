generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Level {
  level_id   Int      @id @default(autoincrement())
  level_name String
  level_code String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  users      User[]

  @@map("levels")
}

model User {
  user_id         Int             @id @default(autoincrement())
  name            String
  email           String          @unique
  password        String
  level_id        Int
  profile_picture String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  workspaces      UserWorkspace[]
  level           Level           @relation(fields: [level_id], references: [level_id])
  owned_workspaces    Workspace[]     @relation("WorkspaceOwner")

  @@map("users")
}

model UserWorkspace {
  user_workspace_id Int       @id @default(autoincrement())
  user_id           Int
  workspace_id      Int
  permision         String
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  user              User      @relation(fields: [user_id], references: [user_id])
  workspace         Workspace @relation(fields: [workspace_id], references: [workspace_id])

  @@map("user_workspaces")
}

model Workspace {
  workspace_id          Int             @id @default(autoincrement())
  workspace_name        String
  workspace_description String
  owner_id              Int
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  owner                 User            @relation("WorkspaceOwner", fields: [owner_id], references: [user_id])
  edges                 Edge[]
  nodes                 Node[]
  users                 UserWorkspace[]
  proxmox_accounts      Proxmox[]

  @@map("workspaces")
}

model Node {
  node_id          Int           @id @default(autoincrement())
  workspace_id     Int
  node_react_id    String
  node_type        String        @default("monitor")
  node_posX        Float
  node_posY        Float
  node_label       String
  node_description String?
  node_ip_address  String
  node_method      String        @default("ICMP")
  node_port        Int?          @default(0)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt
  services         NodeService[]
  workspace        Workspace     @relation(fields: [workspace_id], references: [workspace_id])

  @@unique([workspace_id, node_react_id])
  @@map("nodes")
  
}

model Edge {
  edge_id         Int       @id @default(autoincrement())
  workspace_id    Int
  source_react_id String
  target_react_id String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspace_id], references: [workspace_id])

  @@map("edges")
}

model NodeService {
  node_service_id          Int      @id @default(autoincrement())
  node_id                  Int
  node_service_name        String
  node_service_description String?
  node_service_ip_address  String
  node_service_method      String
  node_service_port        Int?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  node                     Node     @relation(fields: [node_id], references: [node_id])

  @@map("node_services")
}

model Proxmox {
  proxmox_id              Int       @id @default(autoincrement())
  workspace_id            Int
  proxmox_connection_name String
  proxmox_description     String?
  proxmox_host            String
  proxmox_port            Int       @default(8006)
  proxmox_username        String
  proxmox_token_name      String
  proxmox_token_secret    String    @db.Text
  proxmox_is_active       Boolean   @default(true)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  // Relasi ke Workspace
  workspace               Workspace @relation(fields: [workspace_id], references: [workspace_id])

  @@map("proxmox")
}